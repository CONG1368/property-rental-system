# ====== 物业租赁综合管理系统 - 环境配置 ======
# 复制此文件为 .env 并根据实际环境修改

# 应用端口
PORT=3001

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=property_rental
DB_USER=root
DB_PASSWORD=

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT 密钥（生产环境请修改为复杂随机字符串）
JWT_SECRET=property-rental-jwt-secret-key-2026

# 开发模式（development/production）
NODE_ENV=development
