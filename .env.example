# ====== 物业租赁综合管理系统 - 环境配置 ======
# 复制此文件为 .env 并根据需要修改

# 应用端口
PORT=3001

# 数据库方言: sqlite (默认，零配置) 或 mysql (需要安装 MySQL 8.0)
DB_DIALECT=sqlite

# SQLite 配置 (DB_DIALECT=sqlite 时生效)
# 数据库文件路径（相对于 backend 目录）
# DB_STORAGE=./data/database.sqlite

# MySQL 配置 (DB_DIALECT=mysql 时生效)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=property_rental
DB_USER=root
DB_PASSWORD=

# Redis 配置（可选）
# 设为 false 禁用 Redis，系统可正常运行
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT 密钥（生产环境请改为复杂随机字符串）
JWT_SECRET=property-rental-jwt-secret-key-2026

# 环境模式
NODE_ENV=development
